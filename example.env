APP_NAME="Sembark URL Shortener"
APP_ENV=local
APP_KEY=base64:13TbCP/gvcH0JE8Pi1z826SPpF+1OS+WqlXYnvlOLUA=
APP_DEBUG=true
APP_URL=http://localhost:8070

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Default: SQLite, zero setup required.
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# To use MySQL instead, comment out the sqlite lines above and use:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_urlshortner
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
